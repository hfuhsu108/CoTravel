# 複製此檔為 .env 並填入金鑰（.env 已被 .gitignore，切勿提交真實金鑰）。
# 取得方式見 docs/06-環境設定指南.md

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_MAPS_API_KEY=
# 可選：AdvancedMarker 需要的 Map ID。留空時程式 fallback 為 'DEMO_MAP_ID'（dev 足夠）；
# 正式部署到 Google Cloud → Map Management 建一個自家 Map ID 再填入。
VITE_GOOGLE_MAPS_MAP_ID=
# Web Push VAPID 公鑰（提醒推播功能）。用 npx web-push generate-vapid-keys 產生。
# 留空時推播功能不啟用，不影響其他功能。
VITE_VAPID_PUBLIC_KEY=
